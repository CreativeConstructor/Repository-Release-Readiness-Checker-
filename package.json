{
  "name": "release-readiness-checker",
  "version": "1.0.0",
  "description": "DevOps Release Readiness Checker",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "worker": "node src/worker.js",
    "dev:all": "concurrently -n api,worker -c blue,green \"npm run dev\" \"npm run worker\"",
    "migrate": "node scripts/migrate.js",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^21.1.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.76.8",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9"
  },
  "directories": {
    "test": "tests"
  },
  "type": "commonjs"
}
